<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- 백그라운드에서도 다운로드가 유지되도록 포그라운드 서비스로 실행한다.
         Android 14+는 서비스 유형(dataSync) 권한을, Android 13+는 진행 알림 표시를 위해
         POST_NOTIFICATIONS를 요구한다. WAKE_LOCK은 화면이 꺼져도 다운로드가 멈추지 않게 한다. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- 앱 자체 업데이트: 받은 APK를 사용자 동의 하에 설치하기 위한 권한(Android 8+). -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <!-- 레거시 저장소(Android 9 이하는 공용 Download에 직접 쓴다). -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- Android 11+ : yt-dlp가 네이티브 프로세스로 공용 Download/GetTube 폴더에 직접 파일을
         쓰기 때문에 "모든 파일 접근" 권한이 필요하다(네이티브 바이너리는 MediaStore를 쓸 수 없음).
         사용자가 런타임에 시스템 설정에서 허용한다. -->
    <uses-permission
        android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />

    <application
        android:name=".GetTubeApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:requestLegacyExternalStorage="true"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.GetTube">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.GetTube">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- YouTube 등에서 "공유하기" 시 GetTube가 후보로 뜨도록 함.
                 공유된 텍스트(URL)는 MainActivity에서 입력창에 자동으로 채운다. -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
        </activity>

        <!-- 다운로드를 백그라운드에서도 유지하기 위한 포그라운드 서비스. 진행 알림을 표시하고
             활성 다운로드가 없어지면 스스로 종료한다. -->
        <service
            android:name=".download.DownloadService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- 업데이트로 받은 APK를 설치 인텐트에 content:// URI로 넘기기 위한 FileProvider. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>
